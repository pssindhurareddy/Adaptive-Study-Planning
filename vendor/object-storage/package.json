    "directory": "packages/object-storage/frontend"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@studyos/source": "./src/index.ts",
