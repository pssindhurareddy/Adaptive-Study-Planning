  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "echo 'object-storage: pre-built, skipping tsc'",
    "type-check": "tsc --noEmit",
    "biome:check": "biome check --error-on-warnings .",
    "biome:check:fix": "biome check --write --error-on-warnings ."
